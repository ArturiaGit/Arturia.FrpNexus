<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Arturia.FrpNexus.Desktop.Controls"
             xmlns:converters="using:Arturia.FrpNexus.Desktop.Converters"
             xmlns:pages="using:Arturia.FrpNexus.Desktop.ViewModels.Pages"
             x:Class="Arturia.FrpNexus.Desktop.Views.Pages.DashboardPageView"
             x:DataType="pages:DashboardPageViewModel">
    <UserControl.Resources>
        <converters:DashboardNodeStatusTextConverter x:Key="DashboardNodeStatusTextConverter" />
        <converters:LogLevelBrushConverter x:Key="LogLevelBrushConverter" />
        <converters:MetricIconConverter x:Key="MetricIconConverter" />
        <converters:StatusClassesConverter x:Key="StatusClassesConverter" />
    </UserControl.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto"
              RowSpacing="16">
            <ItemsControl ItemsSource="{Binding Metrics}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:MetricTileControl Margin="0,0,12,0" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Grid.Row="1"
                       Classes="helper"
                       Text="{Binding StatusText}" />

            <Grid Grid.Row="2"
                  ColumnDefinitions="4*,8*"
                  ColumnSpacing="16">
                <Border Classes="panel"
                        Padding="16"
                        MinHeight="220">
                    <StackPanel Spacing="12">
                        <TextBlock Classes="section-title"
                                   Text="快速操作" />

                        <Button Classes="primary quick-action"
                                Command="{Binding NavigateToNodesCommand}">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        HorizontalAlignment="Center">
                                <PathIcon Width="18"
                                          Height="18"
                                          Data="{Binding Source=add, Converter={StaticResource MetricIconConverter}}" />
                                <TextBlock FontWeight="SemiBold"
                                           Text="添加新节点" />
                            </StackPanel>
                        </Button>

                        <Button Classes="secondary quick-action"
                                Command="{Binding NavigateToTunnelsCommand}">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        HorizontalAlignment="Center">
                                <PathIcon Width="18"
                                          Height="18"
                                          Data="{Binding Source=route, Converter={StaticResource MetricIconConverter}}" />
                                <TextBlock Text="创建内网穿透隧道" />
                            </StackPanel>
                        </Button>

                        <Button Classes="secondary quick-action"
                                Command="{Binding NavigateToConfigurationsCommand}">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        HorizontalAlignment="Center">
                                <PathIcon Width="18"
                                          Height="18"
                                          Data="{Binding Source=autorenew, Converter={StaticResource MetricIconConverter}}" />
                                <TextBlock Text="查看配置" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Classes="panel"
                        Padding="16"
                        MinHeight="220">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <Grid ColumnDefinitions="*,Auto"
                              Margin="0,0,0,12">
                            <TextBlock Classes="section-title"
                                       Text="近期节点状态" />
                            <Button Grid.Column="1"
                                    Classes="view-all-link"
                                    Command="{Binding NavigateToNodesCommand}"
                                    VerticalAlignment="Center">
                                <TextBlock Classes="helper"
                                           Text="查看全部" />
                            </Button>
                        </Grid>

                        <Grid Grid.Row="1"
                              ColumnDefinitions="3*,2*,2.5*,2.5*"
                              ColumnSpacing="12"
                              Margin="0,0,0,2">
                            <TextBlock Classes="table-header"
                                       Text="节点名称" />
                            <TextBlock Grid.Column="1"
                                       Classes="table-header"
                                       Text="IP 地址" />
                            <TextBlock Grid.Column="2"
                                       Classes="table-header"
                                       Text="运行时间" />
                            <TextBlock Grid.Column="3"
                                       Classes="table-header"
                                       HorizontalAlignment="Right"
                                       Text="状态" />
                        </Grid>

                        <ItemsControl Grid.Row="2"
                                      ItemsSource="{Binding RecentNodes}"
                                      IsVisible="{Binding HasRecentNodes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="table-row">
                                        <Grid ColumnDefinitions="3*,2*,2.5*,2.5*"
                                              ColumnSpacing="12">
                                            <TextBlock Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1"
                                                       Foreground="{StaticResource Brush.TextSecondary}"
                                                       Text="{Binding Host}" />
                                            <TextBlock Grid.Column="2"
                                                       Foreground="{StaticResource Brush.TextSecondary}"
                                                       Text="{Binding Uptime}" />
                                            <Border Grid.Column="3"
                                                    Classes="dashboard-status-badge"
                                                    HorizontalAlignment="Right"
                                                    Classes.success="{Binding ConnectionStatus, Converter={StaticResource StatusClassesConverter}, ConverterParameter=success}"
                                                    Classes.warning="{Binding ConnectionStatus, Converter={StaticResource StatusClassesConverter}, ConverterParameter=warning}"
                                                    Classes.error="{Binding ConnectionStatus, Converter={StaticResource StatusClassesConverter}, ConverterParameter=error}"
                                                    Classes.neutral="{Binding ConnectionStatus, Converter={StaticResource StatusClassesConverter}, ConverterParameter=neutral}">
                                                <TextBlock Classes="status-text"
                                                           Classes.success="{Binding ConnectionStatus, Converter={StaticResource StatusClassesConverter}, ConverterParameter=success}"
                                                           Classes.warning="{Binding ConnectionStatus, Converter={StaticResource StatusClassesConverter}, ConverterParameter=warning}"
                                                           Classes.error="{Binding ConnectionStatus, Converter={StaticResource StatusClassesConverter}, ConverterParameter=error}"
                                                           Classes.neutral="{Binding ConnectionStatus, Converter={StaticResource StatusClassesConverter}, ConverterParameter=neutral}"
                                                           Text="{Binding ConnectionStatus, Converter={StaticResource DashboardNodeStatusTextConverter}}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Grid.Row="2"
                                Background="{StaticResource Brush.SurfaceLow}"
                                BorderBrush="{StaticResource Brush.BorderDefault}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource FrpRadiusControl}"
                                Padding="12"
                                IsVisible="{Binding !HasRecentNodes}">
                            <TextBlock Classes="helper"
                                       HorizontalAlignment="Center"
                                       Text="暂无节点记录" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="3"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="16">
                <Border Classes="panel"
                        Padding="16"
                        MinHeight="250">
                    <Grid RowDefinitions="Auto,*">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    Margin="0,0,0,12">
                            <PathIcon Width="20"
                                      Height="20"
                                      Data="{Binding Source=error, Converter={StaticResource MetricIconConverter}}"
                                      Foreground="{StaticResource Brush.Error}"
                                      VerticalAlignment="Center" />
                            <TextBlock Classes="section-title"
                                       Text="最近错误" />
                        </StackPanel>

                        <ItemsControl Grid.Row="1"
                                      ItemsSource="{Binding Incidents}"
                                      IsVisible="{Binding HasIncidents}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Classes="incident-row">
                                        <Grid ColumnDefinitions="*,Auto"
                                              RowDefinitions="Auto,Auto"
                                              ColumnSpacing="12">
                                            <TextBlock Classes="group-label"
                                                       Foreground="{StaticResource Brush.Error}"
                                                       Text="{Binding Title}" />
                                            <TextBlock Grid.Column="1"
                                                       Classes="helper"
                                                       Text="{Binding Time}" />
                                            <TextBlock Grid.Row="1"
                                                       Grid.ColumnSpan="2"
                                                       Foreground="{StaticResource Brush.TextSecondary}"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding Message}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Grid.Row="1"
                                Background="{StaticResource Brush.SurfaceLow}"
                                BorderBrush="{StaticResource Brush.BorderDefault}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource FrpRadiusControl}"
                                Padding="12"
                                IsVisible="{Binding !HasIncidents}">
                            <TextBlock Classes="helper"
                                       HorizontalAlignment="Center"
                                       Text="暂无近期错误" />
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Background="{StaticResource Brush.Terminal}"
                        BorderBrush="#1F2937"
                        BorderThickness="1"
                        CornerRadius="{StaticResource FrpRadiusPanel}"
                        Padding="16"
                        MinHeight="250">
                    <Grid RowDefinitions="Auto,*">
                        <Grid ColumnDefinitions="*,Auto"
                              Margin="0,0,0,12">
                            <TextBlock Classes="section-title"
                                       Foreground="#EFF1F3"
                                       VerticalAlignment="Center"
                                       Text="系统日志输出" />
                            <Border Grid.Column="1"
                                    Classes="realtime-badge">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6"
                                            VerticalAlignment="Center">
                                    <Ellipse Width="6"
                                             Height="6"
                                             Fill="{StaticResource Brush.Success}"
                                             VerticalAlignment="Center" />
                                    <TextBlock Classes="status-text success"
                                               Text="本地" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <ItemsControl Grid.Row="1"
                                      ItemsSource="{Binding Logs}"
                                      IsVisible="{Binding HasLogs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="72,42,*"
                                          ColumnSpacing="8"
                                          Margin="0,0,0,5">
                                        <TextBlock Classes="code"
                                                   Foreground="{StaticResource Brush.TextMuted}"
                                                   Text="{Binding Timestamp}" />
                                        <TextBlock Grid.Column="1"
                                                   Classes="code"
                                                   Foreground="{Binding Level, Converter={StaticResource LogLevelBrushConverter}}"
                                                   Text="{Binding Level, StringFormat='[{0}]'}" />
                                        <TextBlock Grid.Column="2"
                                                   Classes="code"
                                                   Foreground="{StaticResource Brush.TerminalText}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{Binding Message}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Grid.Row="1"
                                IsVisible="{Binding !HasLogs}"
                                VerticalAlignment="Center">
                            <TextBlock Classes="code"
                                       Foreground="{StaticResource Brush.TerminalText}"
                                       HorizontalAlignment="Center"
                                       Text="暂无本地运行记录" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
