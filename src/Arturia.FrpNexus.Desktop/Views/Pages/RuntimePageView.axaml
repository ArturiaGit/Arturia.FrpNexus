<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Arturia.FrpNexus.Desktop.Controls"
             xmlns:pages="using:Arturia.FrpNexus.Desktop.ViewModels.Pages"
             x:Class="Arturia.FrpNexus.Desktop.Views.Pages.RuntimePageView"
             x:DataType="pages:RuntimePageViewModel">
    <Grid RowDefinitions="Auto,*" RowSpacing="16">
        <Border Classes="command-bar">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <ComboBox Width="150"
                              SelectedIndex="0">
                        <ComboBoxItem Content="全部节点" />
                        <ComboBoxItem Content="Web-Server-HK" />
                        <ComboBoxItem Content="DB-Node-SH" />
                    </ComboBox>
                    <ComboBox Width="130"
                              SelectedIndex="0">
                        <ComboBoxItem Content="全部进程" />
                        <ComboBoxItem Content="frpc" />
                        <ComboBoxItem Content="frps" />
                    </ComboBox>
                    <ComboBox Width="130"
                              SelectedIndex="0">
                        <ComboBoxItem Content="所有状态" />
                        <ComboBoxItem Content="运行中" />
                        <ComboBoxItem Content="已停止" />
                        <ComboBoxItem Content="异常" />
                    </ComboBox>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <Button Classes="primary" Content="启动" />
                    <Button Classes="secondary" Content="停止" />
                    <Button Classes="secondary" Content="重启" />
                    <Button Classes="secondary" Content="刷新" />
                </StackPanel>
            </DockPanel>
        </Border>
        <Grid Grid.Row="1" ColumnDefinitions="*,320" ColumnSpacing="16">
            <Border Classes="panel">
                <Grid RowDefinitions="Auto,*">
                    <Border Padding="16,12"
                            BorderBrush="{StaticResource Brush.BorderDefault}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                    <TextBlock Classes="section-title" Text="远程运行控制" />
                    <TextBlock Classes="helper" Text="当前为 Phase 1 静态占位，后续接入 SSH/SFTP 与远程进程服务。" />
                        </StackPanel>
                    </Border>
                <DataGrid Grid.Row="1" ItemsSource="{Binding Processes}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="进程" Binding="{Binding Name}" Width="2*" />
                        <DataGridTextColumn Header="节点" Binding="{Binding NodeName}" Width="2*" />
                        <DataGridTextColumn Header="类型" Binding="{Binding ProcessKind}" Width="*" />
                        <DataGridTemplateColumn Header="状态" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <controls:StatusBadgeControl DataContext="{Binding Status}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="*" />
                        <DataGridTextColumn Header="运行时间" Binding="{Binding Uptime}" Width="*" />
                        <DataGridTextColumn Header="监听地址" Binding="{Binding ListenAddress}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
                </Grid>
            </Border>
            <Border Grid.Column="1" Classes="panel" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Classes="section-title" Text="部署步骤占位" />
                    <ItemsControl ItemsSource="{Binding DeploymentSteps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:RuntimeStepControl />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
