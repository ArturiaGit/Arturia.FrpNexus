<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Arturia.FrpNexus.Desktop.Controls"
             xmlns:pages="using:Arturia.FrpNexus.Desktop.ViewModels.Pages"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             x:Class="Arturia.FrpNexus.Desktop.Views.Pages.RuntimePageView"
             x:DataType="pages:RuntimePageViewModel">
    <Grid RowDefinitions="Auto,*" RowSpacing="16">
        <Border Classes="command-bar">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <ComboBox Width="150"
                              SelectedIndex="0">
                        <ComboBoxItem Content="全部节点" />
                        <ComboBoxItem Content="Web-Server-HK" />
                        <ComboBoxItem Content="DB-Node-SH" />
                    </ComboBox>
                    <ComboBox Width="130"
                              SelectedIndex="0">
                        <ComboBoxItem Content="全部进程" />
                        <ComboBoxItem Content="frpc" />
                        <ComboBoxItem Content="frps" />
                    </ComboBox>
                    <ComboBox Width="130"
                              SelectedIndex="0">
                        <ComboBoxItem Content="所有状态" />
                        <ComboBoxItem Content="运行中" />
                        <ComboBoxItem Content="已停止" />
                        <ComboBoxItem Content="异常" />
                    </ComboBox>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <Button Classes="primary"
                            Content="启动"
                            Command="{Binding StartSelectedProcessCommand}" />
                    <Button Classes="secondary"
                            Content="停止"
                            Command="{Binding StopSelectedProcessCommand}" />
                    <Button Classes="secondary"
                            Content="重启"
                            Command="{Binding RestartSelectedProcessCommand}" />
                    <Button Classes="secondary"
                            Content="刷新"
                            Command="{Binding RefreshRemoteProcessesCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>
        <Grid Grid.Row="1" ColumnDefinitions="*,320" ColumnSpacing="16">
            <Border Classes="panel">
                <Grid RowDefinitions="Auto,*">
                    <Border Padding="16,12"
                            BorderBrush="{StaticResource Brush.BorderDefault}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                    <TextBlock Classes="section-title" Text="运行记录" />
                    <TextBlock Classes="helper" Text="{Binding StatusText}" />
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="1"
                          RowDefinitions="*,40">
                        <DataGrid ItemsSource="{Binding Processes}"
                                  SelectedItem="{Binding SelectedProcess}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="进程" Binding="{Binding Name}" Width="2*" />
                                <DataGridTextColumn Header="节点" Binding="{Binding NodeName}" Width="2*" />
                                <DataGridTextColumn Header="类型" Binding="{Binding ProcessKind}" Width="*" />
                                <DataGridTemplateColumn Header="状态" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <controls:StatusBadgeControl DataContext="{Binding Status}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="*" />
                                <DataGridTextColumn Header="运行时间" Binding="{Binding Uptime}" Width="*" />
                                <DataGridTextColumn Header="监听地址" Binding="{Binding ListenAddress}" Width="2*" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <DockPanel Grid.Row="1" Background="{StaticResource Brush.SurfaceSubtle}">
                            <TextBlock Classes="helper"
                                       Margin="12,0"
                                       VerticalAlignment="Center"
                                       Text="{Binding ProcessCountText}" />
                            <TextBlock DockPanel.Dock="Right"
                                       Classes="helper"
                                       Margin="12,0"
                                       VerticalAlignment="Center"
                                       Text="本地 SQLite 记录" />
                        </DockPanel>
                    </Grid>
                </Grid>
            </Border>
            <Border Grid.Column="1" Classes="panel" Padding="16">
                <ScrollViewer>
                    <StackPanel Spacing="12">
                        <TextBlock Classes="section-title" Text="远程运行控制" />
                        <TextBlock Classes="helper"
                                   TextWrapping="Wrap"
                                   Text="凭据仅用于本次远程命令。密码、私钥内容和 passphrase 不会写入 SQLite。" />
                        <ComboBox SelectedItem="{Binding SelectedSshAuthenticationMode}">
                            <sys:String>SessionPassword</sys:String>
                            <sys:String>PrivateKey</sys:String>
                            <sys:String>SshAgent</sys:String>
                        </ComboBox>
                        <TextBox Classes="code"
                                 PlaceholderText="私钥文件路径"
                                 Text="{Binding SshPrivateKeyPath}" />
                        <TextBox PasswordChar="*"
                                 PlaceholderText="会话密码，仅本次使用"
                                 Text="{Binding SshSessionPassword}" />
                        <TextBox PasswordChar="*"
                                 PlaceholderText="私钥 passphrase，仅本次使用"
                                 Text="{Binding SshPrivateKeyPassphrase}" />
                        <TextBlock Classes="helper" Text="远程命令" />
                        <TextBox Classes="code"
                                 AcceptsReturn="True"
                                 MinHeight="72"
                                 TextWrapping="Wrap"
                                 Text="{Binding RemoteCommandText}" />

                        <Border Classes="settings-divider" />

                        <TextBlock Classes="section-title" Text="部署步骤" />
                        <ItemsControl ItemsSource="{Binding DeploymentSteps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:RuntimeStepControl />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
