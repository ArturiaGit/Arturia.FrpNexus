<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Arturia.FrpNexus.Desktop.Controls"
             xmlns:pages="using:Arturia.FrpNexus.Desktop.ViewModels.Pages"
             x:Class="Arturia.FrpNexus.Desktop.Views.Pages.SettingsPageView"
             x:DataType="pages:SettingsPageViewModel">
    <ScrollViewer>
        <StackPanel MaxWidth="860"
                    HorizontalAlignment="Center"
                    Spacing="18">
            <TextBlock Classes="section-title" Text="核心设置" />
            <Border Classes="settings-card">
                <StackPanel>
                    <controls:SettingsRowControl Title="FRP 下载源"
                                                 Description="选择核心下载来源">
                        <controls:SettingsRowControl.ValueContent>
                            <ComboBox Classes="stitch-input"
                                      Width="320"
                                      ItemsSource="{Binding FrpDownloadSourceOptions}"
                                      SelectedItem="{Binding SelectedFrpDownloadSourceOption}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="pages:SettingsOptionViewModel">
                                        <TextBlock Text="{Binding DisplayText}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </controls:SettingsRowControl.ValueContent>
                    </controls:SettingsRowControl>

                    <Border Classes="settings-divider" />

                    <controls:SettingsRowControl Title="自定义镜像源"
                                                 Description="填写 GitHub API 兼容 Releases 地址"
                                                 IsVisible="{Binding IsCustomFrpDownloadSourceSelected}">
                        <controls:SettingsRowControl.ValueContent>
                            <StackPanel Spacing="6"
                                        Width="420">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBox Classes="stitch-input code"
                                             PlaceholderText="https://mirror.example.com/repos/fatedier/frp/releases"
                                             Text="{Binding CustomFrpDownloadSourceUrl}" />
                                    <Button Grid.Column="1"
                                            Classes="secondary stitch-command"
                                            Content="保存地址"
                                            Command="{Binding SaveCustomFrpDownloadSourceUrlCommand}" />
                                </Grid>
                                <TextBlock Classes="helper"
                                           TextWrapping="Wrap"
                                           Text="仅使用可信源，避免下载被篡改的 FRP 核心。" />
                            </StackPanel>
                        </controls:SettingsRowControl.ValueContent>
                    </controls:SettingsRowControl>

                    <Border Classes="settings-divider"
                            IsVisible="{Binding IsCustomFrpDownloadSourceSelected}" />

                    <controls:SettingsRowControl Title="FRP 核心下载"
                                                 Description="下载最新版 frpc / frps">
                        <controls:SettingsRowControl.ValueContent>
                            <Grid MinWidth="180"
                                  HorizontalAlignment="Right">
                                <Button Classes="secondary stitch-command"
                                        MinWidth="104"
                                        HorizontalAlignment="Right"
                                        Content="{Binding DownloadLatestFrpReleaseButtonText}"
                                        Command="{Binding DownloadLatestFrpReleaseCommand}" />
                            </Grid>
                        </controls:SettingsRowControl.ValueContent>
                    </controls:SettingsRowControl>
                </StackPanel>
            </Border>

            <TextBlock Classes="section-title" Text="安全与认证" />
            <Border Classes="settings-card">
                <StackPanel>
                    <controls:SettingsRowControl Title="凭据安全中心"
                                                 Description="查看认证状态，不显示密码明文">
                        <controls:SettingsRowControl.ValueContent>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Spacing="8">
                                <Button Classes="secondary stitch-command"
                                        Content="刷新状态"
                                        Command="{Binding RefreshCredentialSecurityCommand}" />
                                <Button Classes="secondary stitch-command danger"
                                        AutomationProperties.Name="清除全部保存密码"
                                        Content="清除全部保存密码"
                                        Command="{Binding ClearAllSavedSessionPasswordsCommand}" />
                            </StackPanel>
                        </controls:SettingsRowControl.ValueContent>
                    </controls:SettingsRowControl>

                    <Border Classes="settings-divider" />

                    <Border Classes="section-surface"
                            Margin="16"
                            Padding="12">
                        <Grid ColumnDefinitions="*,*,*,*,*"
                              ColumnSpacing="12">
                            <StackPanel Spacing="2">
                                <TextBlock Classes="helper" Text="节点总数" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="{Binding CredentialNodeCount}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Classes="helper" Text="会话密码" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="{Binding SessionPasswordNodeCount}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="2">
                                <TextBlock Classes="helper" Text="私钥路径" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="{Binding PrivateKeyNodeCount}" />
                            </StackPanel>
                            <StackPanel Grid.Column="3" Spacing="2">
                                <TextBlock Classes="helper" Text="SSH Agent" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="{Binding SshAgentNodeCount}" />
                            </StackPanel>
                            <StackPanel Grid.Column="4" Spacing="2">
                                <TextBlock Classes="helper" Text="已保存密码" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="{Binding SavedSessionPasswordNodeCount}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Classes="settings-divider" />

                    <Border Classes="section-surface"
                            Margin="16,0,16,16"
                            Padding="0">
                        <StackPanel>
                            <Grid HorizontalAlignment="Stretch"
                                  ColumnDefinitions="2*,1.4*,2*,1.2*,64"
                                  ColumnSpacing="12"
                                  MinHeight="36"
                                  Margin="12,0">
                                <TextBlock Classes="helper"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Text="节点" />
                                <TextBlock Grid.Column="1"
                                           Classes="helper"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Stretch"
                                           TextAlignment="Center"
                                           Text="认证方式" />
                                <TextBlock Grid.Column="2"
                                           Classes="helper"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Text="私钥摘要" />
                                <TextBlock Grid.Column="3"
                                           Classes="helper"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Stretch"
                                           TextAlignment="Center"
                                           Text="保存密码" />
                                <TextBlock Grid.Column="4"
                                           Classes="helper"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Stretch"
                                           TextAlignment="Right"
                                           Text="操作" />
                            </Grid>

                            <Border Classes="settings-divider" />

                            <ItemsControl HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding CredentialSecurityNodes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="pages:CredentialSecurityNodeViewModel">
                                        <Grid HorizontalAlignment="Stretch"
                                              ColumnDefinitions="2*,1.4*,2*,1.2*,64"
                                              ColumnSpacing="12"
                                              MinHeight="42"
                                              Margin="12,0">
                                            <TextBlock VerticalAlignment="Center"
                                                       Text="{Binding NodeName}" />
                                            <TextBlock Grid.Column="1"
                                                       Foreground="{StaticResource Brush.TextSecondary}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Stretch"
                                                       TextAlignment="Center"
                                                       Text="{Binding AuthenticationModeText}" />
                                            <TextBlock Grid.Column="2"
                                                       Classes="code"
                                                       Foreground="{StaticResource Brush.TextSecondary}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding PrivateKeySummary}" />
                                            <TextBlock Grid.Column="3"
                                                       Foreground="{StaticResource Brush.TextSecondary}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Stretch"
                                                       TextAlignment="Center"
                                                       Text="{Binding SavedPasswordStatusText}" />
                                            <Button Grid.Column="4"
                                                    Classes="secondary stitch-command danger compact"
                                                    AutomationProperties.Name="清除该节点保存密码"
                                                    HorizontalAlignment="Right"
                                                    Content="清除"
                                                    Command="{Binding ClearSavedSessionPasswordCommand}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <TextBlock Classes="helper"
                               Margin="16,0,16,12"
                               TextWrapping="Wrap"
                               Text="{Binding CredentialSecurityStatusText}" />

                    <controls:SettingsRowControl Title="安全边界"
                                                 Description="密码仅由当前 Windows 用户 DPAPI 保护，不写入 SQLite 或导出文件">
                    </controls:SettingsRowControl>
                </StackPanel>
            </Border>

            <TextBlock Classes="section-title" Text="日志与本地数据" />
            <Border Classes="settings-card">
                <StackPanel>
                    <controls:SettingsRowControl Title="日志目录"
                                                 Description="本地文件仅记录 Warning 及以上">
                        <controls:SettingsRowControl.ValueContent>
                            <Grid Width="480" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                <TextBox Classes="stitch-input code"
                                         Text="{Binding LogDirectory}" />
                                <Button Grid.Column="1"
                                        Classes="secondary stitch-command"
                                        Content="选择目录"
                                        Command="{Binding SelectLogDirectoryCommand}" />
                                <Button Grid.Column="2"
                                        Classes="secondary stitch-command"
                                        Content="打开目录"
                                        Command="{Binding OpenLogDirectoryCommand}" />
                            </Grid>
                        </controls:SettingsRowControl.ValueContent>
                    </controls:SettingsRowControl>

                    <Border Classes="settings-divider" />

                    <controls:SettingsRowControl Title="SQLite 数据库">
                        <controls:SettingsRowControl.ValueContent>
                            <Grid Width="480" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                <TextBox Classes="stitch-input code"
                                         IsReadOnly="True"
                                         Text="{Binding SqliteDatabasePath}" />
                                <Button Grid.Column="1"
                                        Classes="secondary stitch-command"
                                        Content="选择目录"
                                        Command="{Binding SelectSqliteDatabaseDirectoryCommand}" />
                                <Button Grid.Column="2"
                                        Classes="secondary stitch-command"
                                        Content="打开目录"
                                        Command="{Binding OpenSqliteDatabaseDirectoryCommand}" />
                            </Grid>
                        </controls:SettingsRowControl.ValueContent>
                    </controls:SettingsRowControl>

                    <Border Classes="settings-divider" />

                    <controls:SettingsRowControl Title="日志级别"
                                                 Description="控制台 Information+，文件 Warning+">
                        <controls:SettingsRowControl.ValueContent>
                            <TextBlock Classes="helper"
                                       HorizontalAlignment="Right"
                                       Text="Console: Information+ / File: Warning+" />
                        </controls:SettingsRowControl.ValueContent>
                    </controls:SettingsRowControl>

                    <Border Classes="settings-divider" />

                    <controls:SettingsRowControl Title="本地缓存"
                                                 Description="清理默认 FRP 核心下载缓存，不影响数据库、日志和凭据">
                        <controls:SettingsRowControl.ValueContent>
                            <Grid MinWidth="180"
                                  HorizontalAlignment="Right">
                                <Button Classes="secondary stitch-command"
                                        AutomationProperties.Name="清理本地缓存"
                                        HorizontalAlignment="Right"
                                        Content="清理缓存"
                                        Command="{Binding ClearLocalCacheCommand}" />
                            </Grid>
                        </controls:SettingsRowControl.ValueContent>
                    </controls:SettingsRowControl>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8"
                        Margin="0,6,0,18">
                <TextBlock Classes="helper"
                           VerticalAlignment="Center"
                           Text="{Binding SaveStatusText}" />
                <Button Classes="secondary stitch-command" Content="重置默认" />
                <Button Classes="primary stitch-command"
                        Content="保存应用"
                        Command="{Binding SaveSettingsCommand}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
