<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Arturia.FrpNexus.Desktop.Controls"
             xmlns:pages="using:Arturia.FrpNexus.Desktop.ViewModels.Pages"
             x:Class="Arturia.FrpNexus.Desktop.Views.Pages.SettingsPageView"
             x:DataType="pages:SettingsPageViewModel">
    <ScrollViewer>
        <StackPanel MaxWidth="860"
                    HorizontalAlignment="Center"
                    Spacing="18">
            <TextBlock Classes="section-title" Text="核心设置" />
            <Border Classes="settings-card">
                <StackPanel>
                    <controls:SettingsRowControl Title="FRP 下载源"
                                                 Description="配置 FRP 客户端和服务端核心组件的更新服务源">
                        <controls:SettingsRowControl.ValueContent>
                            <ComboBox Classes="stitch-input"
                                      Width="320"
                                      ItemsSource="{Binding FrpDownloadSourceOptions}"
                                      SelectedItem="{Binding SelectedFrpDownloadSourceOption}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="pages:SettingsOptionViewModel">
                                        <TextBlock Text="{Binding DisplayText}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </controls:SettingsRowControl.ValueContent>
                    </controls:SettingsRowControl>

                    <Border Classes="settings-divider" />

                    <controls:SettingsRowControl Title="FRP 核心目录"
                                                 Description="保存 frpc、frps 及版本缓存的本地目录">
                        <controls:SettingsRowControl.ValueContent>
                            <Grid Width="360" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox Classes="stitch-input code"
                                         Text="{Binding CoreDirectory}" />
                                <Button Grid.Column="1"
                                        Classes="secondary stitch-command"
                                        Content="更改路径" />
                            </Grid>
                        </controls:SettingsRowControl.ValueContent>
                    </controls:SettingsRowControl>

                    <Border Classes="settings-divider" />

                    <controls:SettingsRowControl Title="默认配置目录"
                                                 Description="保存生成的 TOML 配置与导出文件">
                        <controls:SettingsRowControl.ValueContent>
                            <Grid Width="360" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox Classes="stitch-input code"
                                         Text="{Binding ConfigDirectory}" />
                                <Button Grid.Column="1"
                                        Classes="secondary stitch-command"
                                        Content="打开目录" />
                            </Grid>
                        </controls:SettingsRowControl.ValueContent>
                    </controls:SettingsRowControl>
                </StackPanel>
            </Border>

            <TextBlock Classes="section-title" Text="安全与认证" />
            <Border Classes="settings-card">
                <StackPanel>
                    <controls:SettingsRowControl Title="SSH 密钥管理"
                                                 Description="管理用于安全连接到远程 FRP 服务器的私钥凭据；示例仅展示名称、用途和脱敏指纹">
                        <controls:SettingsRowControl.ValueContent>
                            <Button Classes="primary stitch-command"
                                    Content="导入新密钥" />
                        </controls:SettingsRowControl.ValueContent>
                    </controls:SettingsRowControl>

                    <Border Classes="settings-divider" />

                    <Border Classes="subtle-panel"
                            Margin="16"
                            Padding="0">
                        <StackPanel>
                            <Grid ColumnDefinitions="2*,2*,3*,Auto"
                                  ColumnSpacing="12"
                                  MinHeight="36"
                                  Margin="12,0">
                                <TextBlock Classes="helper"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Text="名称" />
                                <TextBlock Grid.Column="1"
                                           Classes="helper"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Text="用途" />
                                <TextBlock Grid.Column="2"
                                           Classes="helper"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Text="Fingerprint" />
                                <TextBlock Grid.Column="3"
                                           Classes="helper"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Right"
                                           Text="操作" />
                            </Grid>

                            <Border Classes="settings-divider" />

                            <ItemsControl ItemsSource="{Binding SshKeys}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="2*,2*,3*,Auto"
                                              ColumnSpacing="12"
                                              MinHeight="42"
                                              Margin="12,0">
                                            <TextBlock VerticalAlignment="Center"
                                                       Text="{Binding Name}" />
                                            <TextBlock Grid.Column="1"
                                                       Foreground="{StaticResource Brush.TextSecondary}"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding Description}" />
                                            <TextBlock Grid.Column="2"
                                                       Classes="code"
                                                       Foreground="{StaticResource Brush.TextSecondary}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding Fingerprint}" />
                                            <StackPanel Grid.Column="3"
                                                        Orientation="Horizontal"
                                                        Spacing="6"
                                                        VerticalAlignment="Center">
                                                <Button Classes="secondary stitch-command compact"
                                                        Content="编辑" />
                                                <Button Classes="secondary stitch-command danger compact"
                                                        Content="删除" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Classes="settings-divider" />

                    <controls:SettingsRowControl Title="敏感信息显示"
                                                 Description="Token、SSH 密码和私钥内容不在界面样例中展示">
                        <controls:SettingsRowControl.ValueContent>
                            <TextBlock Classes="helper"
                                       HorizontalAlignment="Right"
                                       Text="仅显示脱敏摘要" />
                        </controls:SettingsRowControl.ValueContent>
                    </controls:SettingsRowControl>
                </StackPanel>
            </Border>

            <TextBlock Classes="section-title" Text="日志与本地数据" />
            <Border Classes="settings-card">
                <StackPanel>
                    <controls:SettingsRowControl Title="日志目录"
                                                 Description="Serilog 本地文件日志默认记录 Warning 及以上级别">
                        <controls:SettingsRowControl.ValueContent>
                            <Grid Width="360" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox Classes="stitch-input code"
                                         Text="{Binding LogDirectory}" />
                                <Button Grid.Column="1"
                                        Classes="secondary stitch-command"
                                        Content="打开目录" />
                            </Grid>
                        </controls:SettingsRowControl.ValueContent>
                    </controls:SettingsRowControl>

                    <Border Classes="settings-divider" />

                    <controls:SettingsRowControl Title="SQLite 数据库"
                                                 Description="结构化本地数据默认通过 SQLite 保存，由 Application 接口访问">
                        <controls:SettingsRowControl.ValueContent>
                            <TextBox Classes="stitch-input code"
                                     Width="360"
                                     IsReadOnly="True"
                                     Text="{Binding SqliteDatabasePath}" />
                        </controls:SettingsRowControl.ValueContent>
                    </controls:SettingsRowControl>

                    <Border Classes="settings-divider" />

                    <controls:SettingsRowControl Title="日志级别"
                                                 Description="控制台输出 Information 及以上，本地文件记录 Warning 及以上">
                        <controls:SettingsRowControl.ValueContent>
                            <TextBlock Classes="helper"
                                       HorizontalAlignment="Right"
                                       Text="Console: Information+ / File: Warning+" />
                        </controls:SettingsRowControl.ValueContent>
                    </controls:SettingsRowControl>

                    <Border Classes="settings-divider" />

                    <controls:SettingsRowControl Title="本地缓存"
                                                 Description="清理下载缓存、临时配置和旧版本运行产物">
                        <controls:SettingsRowControl.ValueContent>
                            <Button Classes="secondary stitch-command"
                                    Content="清理缓存" />
                        </controls:SettingsRowControl.ValueContent>
                    </controls:SettingsRowControl>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8"
                        Margin="0,6,0,18">
                <TextBlock Classes="helper"
                           VerticalAlignment="Center"
                           Text="{Binding SaveStatusText}" />
                <Button Classes="secondary stitch-command" Content="重置默认" />
                <Button Classes="primary stitch-command"
                        Content="保存应用"
                        Command="{Binding SaveSettingsCommand}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
