<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Arturia.FrpNexus.Desktop.Controls"
             xmlns:converters="using:Arturia.FrpNexus.Desktop.Converters"
             xmlns:pages="using:Arturia.FrpNexus.Desktop.ViewModels.Pages"
             x:Class="Arturia.FrpNexus.Desktop.Views.Pages.LogsPageView"
             x:DataType="pages:LogsPageViewModel">
    <UserControl.Resources>
        <converters:MetricIconConverter x:Key="MetricIconConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*"
          RowSpacing="12"
          MinHeight="0">
        <Border Classes="dense-command-bar">
            <Grid RowDefinitions="Auto,Auto,Auto"
                  RowSpacing="8">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                      ColumnSpacing="10"
                      MinHeight="34">
                    <Grid Classes="search-box"
                          MinWidth="220">
                        <TextBox Classes="stitch-input"
                                 Padding="36,0,12,0"
                                 VerticalContentAlignment="Center"
                                 PlaceholderText="搜索日志内容"
                                 Text="{Binding SearchText}" />
                        <PathIcon Width="18"
                                  Height="18"
                                  Margin="12,0,0,0"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  Foreground="{StaticResource FrpTextSecondaryBrush}"
                                  IsHitTestVisible="False"
                                  Data="{Binding Source=search, Converter={StaticResource MetricIconConverter}}" />
                    </Grid>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <TextBlock Classes="group-label"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource FrpTextSecondaryBrush}"
                                   Text="节点" />
                        <ComboBox Classes="stitch-input"
                                  Width="136"
                                  ItemsSource="{Binding NodeFilterOptions}"
                                  SelectedItem="{Binding SelectedNodeFilter}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <TextBlock Classes="group-label"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource FrpTextSecondaryBrush}"
                                   Text="进程" />
                        <ComboBox Classes="stitch-input"
                                  Width="136"
                                  ItemsSource="{Binding ProcessFilterOptions}"
                                  SelectedItem="{Binding SelectedProcessFilter}" />
                    </StackPanel>

                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <TextBlock Classes="group-label"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource FrpTextSecondaryBrush}"
                                   Text="级别" />
                        <ComboBox Classes="stitch-input"
                                  Width="120"
                                  ItemsSource="{Binding LevelFilterOptions}"
                                  SelectedItem="{Binding SelectedLevelFilter}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1"
                      ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="10"
                      MinHeight="32">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <ToggleButton Classes="log-auto-refresh"
                                      AutomationProperties.Name="自动刷新日志"
                                      IsChecked="{Binding IsAutoRefreshEnabled}" />
                        <TextBlock VerticalAlignment="Center"
                                   Text="自动刷新" />
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Classes="helper"
                               VerticalAlignment="Center"
                               Text="{Binding StatusText}"
                               TextTrimming="CharacterEllipsis" />

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Right">
                        <Button Classes="secondary stitch-command"
                                AutomationProperties.Name="刷新当前日志"
                                MinHeight="32"
                                Height="32"
                                Command="{Binding RefreshLogsCommand}">
                            <ToolTip.Tip>
                                <ToolTip Classes="stitch-tooltip"
                                         Placement="Top"
                                         VerticalOffset="-6"
                                         Content="刷新当前日志" />
                            </ToolTip.Tip>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6">
                                <PathIcon Width="16"
                                          Height="16"
                                          Data="{Binding Source=refresh, Converter={StaticResource MetricIconConverter}}" />
                                <TextBlock Text="刷新" />
                            </StackPanel>
                        </Button>

                        <Button Classes="secondary stitch-command"
                                AutomationProperties.Name="{Binding LogModeToggleText}"
                                MinHeight="32"
                                Height="32"
                                Command="{Binding ToggleRemoteCredentialsCommand}">
                            <ToolTip.Tip>
                                <ToolTip Classes="stitch-tooltip"
                                         Placement="Top"
                                         VerticalOffset="-6"
                                         Content="{Binding LogModeToggleTooltip}" />
                            </ToolTip.Tip>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6">
                                <PathIcon Width="16"
                                          Height="16"
                                          Data="{Binding Source=terminal, Converter={StaticResource MetricIconConverter}}" />
                                <TextBlock Text="{Binding LogModeToggleText}" />
                            </StackPanel>
                        </Button>

                        <Button Classes="secondary stitch-command danger"
                                AutomationProperties.Name="清空日志"
                                MinHeight="32"
                                Height="32"
                                Command="{Binding ClearLogsCommand}">
                            <ToolTip.Tip>
                                <ToolTip Classes="stitch-tooltip"
                                         Placement="Top"
                                         VerticalOffset="-6"
                                         Content="清空日志" />
                            </ToolTip.Tip>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6">
                                <PathIcon Width="16"
                                          Height="16"
                                          Data="{Binding Source=delete, Converter={StaticResource MetricIconConverter}}" />
                                <TextBlock Text="清空" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2"
                        Classes="status-callout info"
                        Padding="10,6"
                        IsVisible="{Binding IsRemoteCredentialsVisible}">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="8">
                        <PathIcon Width="16"
                                  Height="16"
                                  VerticalAlignment="Center"
                                  Classes="status-callout-icon info"
                                  Data="{Binding Source=folder, Converter={StaticResource MetricIconConverter}}" />
                        <TextBlock Grid.Column="1"
                                   Classes="helper code"
                                   VerticalAlignment="Center"
                                   Text="{Binding RemoteLogPath}"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Classes="terminal-panel">
            <Grid RowDefinitions="28,*,24"
                  MinHeight="0">
                <DockPanel Classes="terminal-header">
                    <StackPanel Orientation="Horizontal"
                                Spacing="6"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center">
                        <Ellipse Width="10"
                                 Height="10"
                                 Fill="#8A94A3" />
                        <Ellipse Width="10"
                                 Height="10"
                                 Fill="#8A94A3" />
                        <Ellipse Width="10"
                                 Height="10"
                                 Fill="#8A94A3" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                Spacing="16"
                                Margin="16,0,12,0"
                                VerticalAlignment="Center">
                        <TextBlock Classes="code"
                                   Foreground="{StaticResource FrpCodeMutedBrush}"
                                   Text="Terminal - FrpNexus Core" />
                        <TextBlock Classes="code"
                                   Foreground="{StaticResource FrpCodeMutedBrush}"
                                   Text="{Binding TerminalConnectionText}" />
                        <TextBlock Classes="code"
                                   Foreground="{StaticResource FrpCodeMutedBrush}"
                                   Text="{Binding StatusText}" />
                    </StackPanel>
                </DockPanel>

                <ScrollViewer Grid.Row="1"
                              Margin="12"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding VisibleLogs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:LogLineControl Margin="0,0,0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <DockPanel Grid.Row="2"
                           Classes="terminal-footer">
                    <TextBlock Classes="code"
                               Margin="12,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource FrpCodeMutedBrush}"
                               Text="{Binding LogFileText}" />
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                Spacing="16"
                                Margin="12,0"
                                VerticalAlignment="Center">
                        <TextBlock Classes="code"
                                   Foreground="{StaticResource FrpCodeMutedBrush}"
                                   Text="{Binding LinesText}" />
                        <TextBlock Classes="code"
                                   Foreground="{StaticResource FrpCodeMutedBrush}"
                                   Text="Encoding: UTF-8" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
