<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Arturia.FrpNexus.Desktop.Controls"
             xmlns:converters="using:Arturia.FrpNexus.Desktop.Converters"
             xmlns:pages="using:Arturia.FrpNexus.Desktop.ViewModels.Pages"
             x:Class="Arturia.FrpNexus.Desktop.Views.Pages.LogsPageView"
             x:DataType="pages:LogsPageViewModel">
    <UserControl.Resources>
        <converters:MetricIconConverter x:Key="MetricIconConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="ToggleButton.log-auto-refresh">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="20" />
            <Setter Property="MinHeight" Value="20" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource FrpSurfaceVariantBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource FrpSurfaceVariantBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <Ellipse x:Name="PART_Knob"
                                 Width="16"
                                 Height="16"
                                 Margin="2,2,14,2"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Center"
                                 Fill="{DynamicResource FrpSurfaceWhiteBrush}">
                            <Ellipse.Transitions>
                                <Transitions>
                                    <ThicknessTransition Property="Margin" Duration="0:0:0.16" />
                                </Transitions>
                            </Ellipse.Transitions>
                        </Ellipse>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="ToggleButton.log-auto-refresh:checked">
            <Setter Property="Background" Value="{DynamicResource FrpPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource FrpPrimaryBrush}" />
        </Style>

        <Style Selector="ToggleButton.log-auto-refresh:checked /template/ Ellipse#PART_Knob">
            <Setter Property="Margin" Value="14,2,2,2" />
        </Style>

        <Style Selector="ToggleButton.log-auto-refresh:pointerover">
            <Setter Property="Background" Value="{DynamicResource FrpSurfaceDimBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource FrpOutlineVariantBrush}" />
        </Style>

        <Style Selector="ToggleButton.log-auto-refresh:pressed">
            <Setter Property="Background" Value="{DynamicResource FrpSurfaceHighBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource FrpOutlineVariantBrush}" />
        </Style>

        <Style Selector="ToggleButton.log-auto-refresh:checked:pointerover">
            <Setter Property="Background" Value="{DynamicResource FrpPrimaryHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource FrpPrimaryHoverBrush}" />
        </Style>

        <Style Selector="ToggleButton.log-auto-refresh:checked:pressed">
            <Setter Property="Background" Value="{DynamicResource FrpPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource FrpPrimaryBrush}" />
        </Style>

        <Style Selector="ToggleButton.log-auto-refresh:disabled">
            <Setter Property="Background" Value="{DynamicResource FrpSurfaceLowBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
            <Setter Property="Opacity" Value="0.55" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*"
          RowSpacing="12"
          MinHeight="0">
        <Border Classes="command-bar">
            <Grid RowDefinitions="Auto,Auto"
                  RowSpacing="4">
                <WrapPanel Grid.Row="0"
                           Orientation="Horizontal"
                           VerticalAlignment="Center">
                    <Grid Width="256"
                          Height="34"
                          Margin="0,0,12,8">
                        <TextBox Classes="stitch-input"
                                 Padding="36,0,12,0"
                                 VerticalContentAlignment="Center"
                                 PlaceholderText="搜索日志内容..."
                                 Text="{Binding SearchText}" />
                        <PathIcon Width="18"
                                  Height="18"
                                  Margin="12,0,0,0"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  Foreground="{StaticResource FrpTextSecondaryBrush}"
                                  IsHitTestVisible="False"
                                  Data="{Binding Source=search, Converter={StaticResource MetricIconConverter}}" />
                    </Grid>

                    <Border Width="1"
                            Height="24"
                            Margin="0,5,12,8"
                            Background="{StaticResource FrpBorderDefaultBrush}" />

                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                Margin="0,0,12,8"
                                VerticalAlignment="Center">
                        <TextBlock Classes="group-label"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource FrpTextSecondaryBrush}"
                                   Text="节点:" />
                        <ComboBox Classes="stitch-input"
                                  Width="132"
                                  ItemsSource="{Binding NodeFilterOptions}"
                                  SelectedItem="{Binding SelectedNodeFilter}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                Margin="0,0,12,8"
                                VerticalAlignment="Center">
                        <TextBlock Classes="group-label"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource FrpTextSecondaryBrush}"
                                   Text="进程:" />
                        <ComboBox Classes="stitch-input"
                                  Width="132"
                                  ItemsSource="{Binding ProcessFilterOptions}"
                                  SelectedItem="{Binding SelectedProcessFilter}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                Margin="0,0,12,8"
                                VerticalAlignment="Center">
                        <TextBlock Classes="group-label"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource FrpTextSecondaryBrush}"
                                   Text="级别:" />
                        <ComboBox Classes="stitch-input"
                                  Width="120"
                                  ItemsSource="{Binding LevelFilterOptions}"
                                  SelectedItem="{Binding SelectedLevelFilter}" />
                    </StackPanel>
                </WrapPanel>

                <WrapPanel Grid.Row="1"
                           Orientation="Horizontal"
                           VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center">
                        <ToggleButton Classes="log-auto-refresh"
                                      IsChecked="{Binding IsAutoRefreshEnabled}" />
                        <TextBlock VerticalAlignment="Center"
                                   Text="自动刷新" />
                    </StackPanel>

                    <Border Width="1"
                            Height="24"
                            Margin="0,4,12,4"
                            Background="{StaticResource FrpBorderDefaultBrush}" />

                    <Button Classes="secondary stitch-command"
                            MinHeight="32"
                            Height="32"
                            Margin="0,0,8,0">
                        <ToolTip.Tip>
                            <ToolTip Classes="stitch-tooltip"
                                     Placement="Top"
                                     VerticalOffset="-6"
                                     Content="复制日志" />
                        </ToolTip.Tip>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="6">
                            <PathIcon Width="16"
                                      Height="16"
                                      Data="{Binding Source=content_copy, Converter={StaticResource MetricIconConverter}}" />
                            <TextBlock Text="复制" />
                        </StackPanel>
                    </Button>

                    <Button Classes="secondary stitch-command danger"
                            MinHeight="32"
                            Height="32"
                            Command="{Binding ClearLogsCommand}">
                        <ToolTip.Tip>
                            <ToolTip Classes="stitch-tooltip"
                                     Placement="Top"
                                     VerticalOffset="-6"
                                     Content="清空日志" />
                        </ToolTip.Tip>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="6">
                            <PathIcon Width="16"
                                      Height="16"
                                      Data="{Binding Source=delete, Converter={StaticResource MetricIconConverter}}" />
                            <TextBlock Text="清空" />
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Classes="terminal-panel">
            <Grid RowDefinitions="28,*,24"
                  MinHeight="0">
                <DockPanel Classes="terminal-header">
                    <StackPanel Orientation="Horizontal"
                                Spacing="6"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center">
                        <Ellipse Width="10"
                                 Height="10"
                                 Fill="#8A94A3" />
                        <Ellipse Width="10"
                                 Height="10"
                                 Fill="#8A94A3" />
                        <Ellipse Width="10"
                                 Height="10"
                                 Fill="#8A94A3" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                Spacing="16"
                                Margin="16,0,12,0"
                                VerticalAlignment="Center">
                        <TextBlock Classes="code"
                                   Foreground="{StaticResource FrpCodeMutedBrush}"
                                   Text="Terminal - FrpNexus Core" />
                        <TextBlock Classes="code"
                                   Foreground="{StaticResource FrpCodeMutedBrush}"
                                   Text="{Binding TerminalConnectionText}" />
                        <TextBlock Classes="code"
                                   Foreground="{StaticResource FrpCodeMutedBrush}"
                                   Text="{Binding StatusText}" />
                    </StackPanel>
                </DockPanel>

                <ScrollViewer Grid.Row="1"
                              Margin="12"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding VisibleLogs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:LogLineControl Margin="0,0,0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <DockPanel Grid.Row="2"
                           Classes="terminal-footer">
                    <TextBlock Classes="code"
                               Margin="12,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource FrpCodeMutedBrush}"
                               Text="File: frpc_client_daemon.log" />
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                Spacing="16"
                                Margin="12,0"
                                VerticalAlignment="Center">
                        <TextBlock Classes="code"
                                   Foreground="{StaticResource FrpCodeMutedBrush}"
                                   Text="{Binding LinesText}" />
                        <TextBlock Classes="code"
                                   Foreground="{StaticResource FrpCodeMutedBrush}"
                                   Text="Encoding: UTF-8" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
