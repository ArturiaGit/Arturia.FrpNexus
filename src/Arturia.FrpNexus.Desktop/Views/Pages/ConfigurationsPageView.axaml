<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Arturia.FrpNexus.Desktop.Controls"
             xmlns:pages="using:Arturia.FrpNexus.Desktop.ViewModels.Pages"
             x:Class="Arturia.FrpNexus.Desktop.Views.Pages.ConfigurationsPageView"
             x:DataType="pages:ConfigurationsPageViewModel">
    <Grid ColumnDefinitions="*,*"
          ColumnSpacing="16">
        <Border Classes="panel">
            <Grid RowDefinitions="Auto,*">
                <Border Classes="command-bar"
                        Margin="12">
                    <DockPanel LastChildFill="False">
                        <TextBlock Classes="section-title"
                                   VerticalAlignment="Center"
                                   Text="可视化编辑" />
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center">
                            <Button Classes="secondary compact"
                                    Content="生成 TOML"
                                    Command="{Binding GenerateTomlCommand}" />
                            <Button Classes="secondary compact"
                                    Content="上传配置" />
                            <Button Classes="primary"
                                    Content="保存配置"
                                    Command="{Binding SaveConfigurationCommand}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <ScrollViewer Grid.Row="1">
                    <StackPanel Margin="16" Spacing="18">
                        <TextBlock Classes="group-label" Text="本地配置版本" />
                        <Border Classes="subtle-panel"
                                Padding="12">
                            <StackPanel Spacing="8">
                                <ComboBox ItemsSource="{Binding Configurations}"
                                          SelectedItem="{Binding SelectedConfiguration}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Classes="helper"
                                           Text="{Binding ConfigurationCountText}" />
                            </StackPanel>
                        </Border>

                        <TextBlock Classes="group-label" Text="基本信息" />
                        <StackPanel Spacing="6">
                            <TextBlock Text="代理名称 *" />
                            <TextBox Text="{Binding ProxyName}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="代理类型" />
                            <ComboBox ItemsSource="{Binding ProtocolOptions}"
                                      SelectedItem="{Binding SelectedProtocol}" />
                        </StackPanel>
                        <TextBlock Classes="group-label" Text="本地配置" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <StackPanel Spacing="6">
                                <TextBlock Text="本地 IP" />
                                <TextBox Classes="code"
                                         Text="{Binding LocalAddress}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="本地端口" />
                                <TextBox Classes="code"
                                         Text="{Binding LocalPort}" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Classes="group-label" Text="远程配置" />
                        <StackPanel Spacing="6">
                            <TextBlock Text="远程端点 (HTTP/HTTPS 使用域名，TCP/UDP 使用远程端口)" />
                            <TextBox Classes="code"
                                     Text="{Binding RemoteEndpoint}" />
                        </StackPanel>

                        <TextBlock Classes="group-label" Text="高级选项" />
                        <Border Classes="subtle-panel"
                                Padding="12">
                            <StackPanel Classes="info-section">
                                <controls:KeyValueRowControl Label="加密传输"
                                                             Value="待配置" />
                                <controls:KeyValueRowControl Label="压缩传输"
                                                             Value="待配置" />
                                <controls:KeyValueRowControl Label="Token"
                                                             Value="不在界面明文显示" />
                            </StackPanel>
                        </Border>

                        <Border Classes="subtle-panel"
                                Padding="12">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="group-label"
                                           Text="本地状态" />
                                <TextBlock Classes="helper"
                                           TextWrapping="Wrap"
                                           Text="{Binding StatusText}" />
                                <TextBlock Classes="helper"
                                           Foreground="{StaticResource Brush.Error}"
                                           TextWrapping="Wrap"
                                           Text="{Binding ErrorText}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
        <Border Grid.Column="1"
                Classes="terminal-panel">
            <Grid RowDefinitions="Auto,*">
                <DockPanel Classes="terminal-header"
                           LastChildFill="False"
                           Height="44">
                    <TextBlock Classes="section-title"
                               Margin="16,0"
                               VerticalAlignment="Center"
                               Foreground="#EFF1F3"
                               Text="frpc.toml 预览" />
                    <StackPanel DockPanel.Dock="Right"
                                Margin="0,0,16,0"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <Button Classes="secondary compact"
                                Foreground="#C9D1D9"
                                Content="验证语法"
                                Command="{Binding ValidateTomlCommand}" />
                        <Button Classes="secondary compact"
                                Foreground="#C9D1D9"
                                Content="复制" />
                    </StackPanel>
                </DockPanel>
                <ScrollViewer Grid.Row="1" Margin="16">
                    <TextBlock Classes="code"
                               Foreground="{StaticResource Brush.TerminalText}"
                               Text="{Binding TomlPreview}" />
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
