<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:Arturia.FrpNexus.Desktop.Converters"
             xmlns:pages="using:Arturia.FrpNexus.Desktop.ViewModels.Pages"
             x:Class="Arturia.FrpNexus.Desktop.Views.Pages.ConfigurationsPageView"
             x:DataType="pages:ConfigurationsPageViewModel">
    <UserControl.Resources>
        <converters:MetricIconConverter x:Key="MetricIconConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Border.config-section-header">
            <Setter Property="Padding" Value="0,0,0,4" />
            <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style Selector="TextBlock.toml-line-number">
            <Setter Property="FontFamily" Value="{DynamicResource Font.Code}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="LineHeight" Value="18" />
            <Setter Property="Foreground" Value="{DynamicResource FrpCodeLineNumberBrush}" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>

        <Style Selector="TextBlock.toml-token">
            <Setter Property="FontFamily" Value="{DynamicResource Font.Code}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="LineHeight" Value="18" />
            <Setter Property="Foreground" Value="{DynamicResource FrpInverseTextBrush}" />
        </Style>

        <Style Selector="TextBlock.toml-token.key">
            <Setter Property="Foreground" Value="{DynamicResource FrpCodeKeyBrush}" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>

        <Style Selector="TextBlock.toml-token.string">
            <Setter Property="Foreground" Value="{DynamicResource FrpStatusSuccessBrush}" />
        </Style>

        <Style Selector="TextBlock.toml-token.number">
            <Setter Property="Foreground" Value="{DynamicResource FrpStatusInfoBrush}" />
        </Style>

        <Style Selector="TextBlock.toml-token.section">
            <Setter Property="Foreground" Value="{DynamicResource FrpStatusNeutralBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="300,*"
          ColumnSpacing="14">
        <Border Classes="inspector-panel"
                Width="300"
                Margin="0"
                ClipToBounds="True">
            <Grid RowDefinitions="Auto,*">
                <Border Classes="inspector-header">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="inspector-kicker"
                                   Text="配置来源" />
                        <TextBlock Classes="section-title"
                                   Text="frpc.toml 只读预览" />
                        <TextBlock Classes="helper"
                                   Text="选择节点后预览会自动更新。" />
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1">
                    <StackPanel Margin="16"
                                Spacing="14">
                        <StackPanel Spacing="7">
                            <Border Classes="config-section-header">
                                <TextBlock Classes="group-label" Text="目标节点" />
                            </Border>
                            <ComboBox Classes="stitch-input"
                                      ItemsSource="{Binding TargetNodes}"
                                      SelectedItem="{Binding SelectedTargetNode}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Classes="helper"
                                       Text="{Binding TargetNodeCountText}" />
                        </StackPanel>

                        <StackPanel Spacing="7">
                            <Border Classes="config-section-header">
                                <TextBlock Classes="group-label" Text="已启用隧道来源" />
                            </Border>
                            <TextBlock Classes="helper"
                                       TextWrapping="Wrap"
                                       Text="{Binding ClientConfigSourceText}" />
                            <Border Classes="subtle-panel"
                                    Padding="10">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8">
                                    <TextBlock Classes="group-label"
                                               Text="{Binding ClientTunnelCountText}"
                                               TextTrimming="CharacterEllipsis" />
                                    <Button Grid.Column="1"
                                            Classes="icon-secondary"
                                            AutomationProperties.Name="刷新隧道来源"
                                            ToolTip.Tip="刷新来源"
                                            Command="{Binding RefreshClientTunnelsCommand}">
                                        <PathIcon Width="16"
                                                  Height="16"
                                                  Data="{Binding Source=refresh, Converter={StaticResource MetricIconConverter}}" />
                                    </Button>
                                </Grid>
                            </Border>
                            <ItemsControl ItemsSource="{Binding ClientTunnels}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="8"
                                              MinHeight="24">
                                            <TextBlock Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1"
                                                       Classes="helper code"
                                                       Text="{Binding RemoteEndpoint}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <Border Classes="status-callout info"
                                Padding="10,8">
                            <TextBlock Classes="helper"
                                       TextWrapping="Wrap"
                                       Text="{Binding StatusText}" />
                        </Border>
                        <TextBlock Classes="helper"
                                   Foreground="{DynamicResource Brush.Error}"
                                   TextWrapping="Wrap"
                                   Text="{Binding ErrorText}" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Classes="editor-shell"
                ClipToBounds="True">
            <Grid RowDefinitions="Auto,*">
                <Border MinHeight="56"
                        Padding="16,0"
                        Background="{DynamicResource FrpTerminalSurfaceBrush}"
                        BorderBrush="{DynamicResource FrpInverseSurfaceBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="12"
                          VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center">
                            <PathIcon Width="18"
                                      Height="18"
                                      Foreground="{DynamicResource FrpCodeMutedBrush}"
                                      Data="{Binding Source=code, Converter={StaticResource MetricIconConverter}}" />
                            <TextBlock Classes="section-title"
                                       Foreground="{DynamicResource FrpInverseTextBrush}"
                                       Text="frpc.toml 预览" />
                            <Border Classes="protocol-badge"
                                    Background="#182563EB"
                                    BorderBrush="{DynamicResource FrpStatusInfoBrush}">
                                <TextBlock Classes="protocol-text"
                                           Foreground="{DynamicResource FrpInverseTextBrush}"
                                           Text="只读" />
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center">
                            <Button Classes="code-command stitch-command"
                                    Command="{Binding ValidateTomlCommand}">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6">
                                    <PathIcon Width="16"
                                              Height="16"
                                              Data="{Binding Source=check_circle, Converter={StaticResource MetricIconConverter}}" />
                                    <TextBlock Text="验证语法" />
                                </StackPanel>
                            </Button>
                            <Button Classes="code-command stitch-command"
                                    Command="{Binding CopyTomlCommand}">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6">
                                    <PathIcon Width="16"
                                              Height="16"
                                              Data="{Binding Source=content_copy, Converter={StaticResource MetricIconConverter}}" />
                                    <TextBlock Text="复制" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <TextBlock Grid.Row="1"
                                   Grid.ColumnSpan="2"
                                   Classes="helper"
                                   Foreground="{DynamicResource FrpCodeMutedBrush}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding PreviewActionStatusText}" />
                    </Grid>
                </Border>

                <Grid Grid.Row="1"
                      ColumnDefinitions="40,*">
                    <Border Background="{DynamicResource FrpCodePanelGutterBrush}"
                            BorderBrush="{DynamicResource FrpInverseSurfaceBrush}"
                            BorderThickness="0,0,1,0" />
                    <ScrollViewer Grid.ColumnSpan="2"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TomlPreviewLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="pages:TomlPreviewLineViewModel">
                                    <Grid ColumnDefinitions="40,*"
                                          MinHeight="18">
                                        <TextBlock Classes="toml-line-number"
                                                   Margin="0,0,8,0"
                                                   Text="{Binding Number}" />
                                        <ItemsControl Grid.Column="1"
                                                      ItemsSource="{Binding Tokens}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="pages:TomlPreviewTokenViewModel">
                                                    <TextBlock Classes="toml-token"
                                                               Classes.key="{Binding IsKey}"
                                                               Classes.string="{Binding IsString}"
                                                               Classes.number="{Binding IsNumber}"
                                                               Classes.section="{Binding IsSection}"
                                                               Text="{Binding Text}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
