<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Arturia.FrpNexus.Desktop.ViewModels"
        xmlns:converters="using:Arturia.FrpNexus.Desktop.Converters"
        xmlns:dialogs="using:Arturia.FrpNexus.Desktop.ViewModels.Dialogs"
        xmlns:pages="using:Arturia.FrpNexus.Desktop.ViewModels.Pages"
        xmlns:desktopModels="using:Arturia.FrpNexus.Desktop.Models"
        xmlns:dialogViews="using:Arturia.FrpNexus.Desktop.Views.Dialogs"
        xmlns:pageViews="using:Arturia.FrpNexus.Desktop.Views.Pages"
        xmlns:transitions="using:Arturia.FrpNexus.Desktop.Transitions"
        xmlns:attached="using:Arturia.FrpNexus.Desktop.AttachedProperties"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Arturia.FrpNexus.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/frpnexus-logo.ico"
        Title="Arturia.FrpNexus"
        Width="1280"
        Height="800"
        MinWidth="1100"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.AppBackground}">

    <Window.Resources>
        <StreamGeometry x:Key="Logo">M9 1.5L1.5 16.5H4.875L9 8.25L13.125 16.5H16.5L9 1.5V1.5</StreamGeometry>
        <converters:MetricIconConverter x:Key="MetricIconConverter" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Grid.dialog-host">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity"
                                      Duration="{DynamicResource FrpMotionDialogEnterDuration}"
                                      Easing="{DynamicResource FrpMotionEaseOut}" />
                </Transitions>
            </Setter>
        </Style>
    </Window.Styles>

    <Window.DataTemplates>
        <DataTemplate DataType="pages:DashboardPageViewModel">
            <pageViews:DashboardPageView />
        </DataTemplate>
        <DataTemplate DataType="pages:NodesPageViewModel">
            <pageViews:NodesPageView />
        </DataTemplate>
        <DataTemplate DataType="pages:TunnelsPageViewModel">
            <pageViews:TunnelsPageView />
        </DataTemplate>
        <DataTemplate DataType="pages:ConfigurationsPageViewModel">
            <pageViews:ConfigurationsPageView />
        </DataTemplate>
        <DataTemplate DataType="pages:RuntimePageViewModel">
            <pageViews:RuntimePageView />
        </DataTemplate>
        <DataTemplate DataType="pages:LogsPageViewModel">
            <pageViews:LogsPageView />
        </DataTemplate>
        <DataTemplate DataType="pages:SettingsPageViewModel">
            <pageViews:SettingsPageView />
        </DataTemplate>
        <DataTemplate DataType="dialogs:NodeConnectionWorkflowViewModel">
            <dialogViews:NodeConnectionWorkflowDialogView />
        </DataTemplate>
        <DataTemplate DataType="dialogs:ConfirmationDialogViewModel">
            <dialogViews:ConfirmationDialogView />
        </DataTemplate>
        <DataTemplate DataType="dialogs:FrpCoreDownloadOptionsDialogViewModel">
            <dialogViews:FrpCoreDownloadOptionsDialogView />
        </DataTemplate>
    </Window.DataTemplates>

    <Grid ColumnDefinitions="212,*">
        <Border Background="{DynamicResource Brush.SidebarBackground}"
                BorderBrush="{DynamicResource Brush.BorderDefault}"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto"
                  Margin="0,24">
                <StackPanel Grid.Row="0"
                            Margin="16,0,16,24"
                            Spacing="2">
                    <Grid ColumnDefinitions="34,*"
                            ColumnSpacing="10">
                        <Border Width="32"
                                Height="32"
                                CornerRadius="8"
                                Background="#152238">
                            <PathIcon Width="18"
                                      Height="18"
                                      Data="{StaticResource Logo}"
                                      Foreground="White"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock Classes="section-title"
                                       Foreground="{DynamicResource Brush.SidebarText}"
                                       Text="FrpNexus" />
                            <TextBlock Classes="helper"
                                       Foreground="{DynamicResource Brush.SidebarMuted}"
                                       Text="v0.4.0-preview.1" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding NavigationItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="desktopModels:NavigationItem">
                            <Button Command="{Binding NavigateCommand}"
                                    CommandParameter="{Binding}"
                                    Classes="nav-button"
                                    AutomationProperties.Name="{Binding Title}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Margin="0,1">
                                <Border Classes.nav-item="True"
                                        Classes.selected="{Binding IsSelected}">
                                    <Grid Height="40"
                                          ColumnDefinitions="3,36,*">
                                        <Border Grid.Column="0"
                                                Background="{DynamicResource Brush.Primary}"
                                                IsVisible="{Binding IsSelected}" />
                                        <PathIcon Grid.Column="1"
                                                  Data="{Binding Icon, Converter={StaticResource NavigationIconConverter}}"
                                                  Classes="nav-icon" />
                                        <TextBlock Grid.Column="2"
                                                   Classes="group-label nav-title"
                                                   Foreground="{DynamicResource Brush.SidebarText}"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding Title}" />
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <Grid Grid.Column="1"
              RowDefinitions="52,*"
              Background="{DynamicResource Brush.AppBackground}">
            <Border Grid.Row="0"
                    Background="{DynamicResource Brush.SurfaceAcrylic}"
                    BorderBrush="{DynamicResource Brush.BorderDefault}"
                    BorderThickness="0,0,0,1">
                <DockPanel Margin="24,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Classes="page-title"
                                   VerticalAlignment="Center"
                                   Text="{Binding CurrentPageTitle}" />
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="12"
                                VerticalAlignment="Center">
                        <Border Classes="topbar-status-badge success">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6"
                                        VerticalAlignment="Center">
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="{DynamicResource Brush.Success}"
                                         VerticalAlignment="Center" />
                                <TextBlock Classes="status-text success"
                                           VerticalAlignment="Center"
                                           Text="{Binding ConnectionText}" />
                            </StackPanel>
                        </Border>
                        <Button Classes="icon-secondary"
                                AutomationProperties.Name="通知"
                                ToolTip.Tip="通知">
                            <PathIcon Width="16"
                                      Height="16"
                                      Data="{Binding Source=notifications, Converter={StaticResource MetricIconConverter}}" />
                        </Button>
                        <Button Classes="icon-secondary"
                                AutomationProperties.Name="网络状态"
                                ToolTip.Tip="网络">
                            <PathIcon Width="16"
                                      Height="16"
                                      Data="{Binding Source=lan, Converter={StaticResource MetricIconConverter}}" />
                        </Button>
                        <Button Classes="icon-secondary"
                                AutomationProperties.Name="同步状态"
                                ToolTip.Tip="同步">
                            <PathIcon Width="16"
                                      Height="16"
                                      Data="{Binding Source=cloud_done, Converter={StaticResource MetricIconConverter}}" />
                        </Button>
                    </StackPanel>
                    </Grid>
                </DockPanel>
            </Border>

            <TransitioningContentControl Grid.Row="1"
                                         Margin="{DynamicResource FrpPageMargin}"
                                         Content="{Binding CurrentPage}">
                <TransitioningContentControl.PageTransition>
                    <transitions:FadeTranslatePageTransition Duration="0:0:0.18"
                                                             Offset="8">
                        <transitions:FadeTranslatePageTransition.Easing>
                            <SineEaseOut />
                        </transitions:FadeTranslatePageTransition.Easing>
                    </transitions:FadeTranslatePageTransition>
                </TransitioningContentControl.PageTransition>
            </TransitioningContentControl>
        </Grid>

        <Border Grid.ColumnSpan="2"
                Background="{DynamicResource Brush.ModalOverlay}"
                IsHitTestVisible="True"
                IsVisible="{Binding IsModalOverlayVisible}"
                ZIndex="1000">
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity"
                                      Duration="{DynamicResource FrpMotionFastDuration}"
                                      Easing="{DynamicResource FrpMotionEaseOut}" />
                </Transitions>
            </Border.Transitions>
        </Border>

        <Grid Grid.ColumnSpan="2"
              Classes="dialog-host"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Opacity="{Binding IsFrpCoreDownloadOptionsDialogVisible, Converter={StaticResource BoolToDoubleConverter}, ConverterParameter='1,0'}"
              IsVisible="{Binding IsFrpCoreDownloadOptionsDialogVisible}"
              attached:DialogEntranceMotion.IsEnabled="True"
              ZIndex="1001">
            <Border Width="480"
                    MaxHeight="420"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource FrpSurfaceWhiteBrush}"
                    BorderBrush="{DynamicResource FrpBorderDefaultBrush}"
                    BorderThickness="1"
                    BoxShadow="{DynamicResource FrpShadowDialog}"
                    CornerRadius="{DynamicResource FrpRadiusPanel}"
                    ClipToBounds="True">
                <ContentControl Content="{Binding CurrentModalDialog}" />
            </Border>
        </Grid>

        <Grid Grid.ColumnSpan="2"
              Classes="dialog-host"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Opacity="{Binding IsConfirmationDialogVisible, Converter={StaticResource BoolToDoubleConverter}, ConverterParameter='1,0'}"
              IsVisible="{Binding IsConfirmationDialogVisible}"
              attached:DialogEntranceMotion.IsEnabled="True"
              ZIndex="1001">
            <Border Width="460"
                    MaxHeight="360"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource FrpSurfaceWhiteBrush}"
                    BorderBrush="{DynamicResource FrpBorderDefaultBrush}"
                    BorderThickness="1"
                    BoxShadow="{DynamicResource FrpShadowDialog}"
                    CornerRadius="{DynamicResource FrpRadiusPanel}"
                    ClipToBounds="True">
                <ContentControl Content="{Binding CurrentModalDialog}" />
            </Border>
        </Grid>

        <Grid Grid.ColumnSpan="2"
              Classes="dialog-host"
              Margin="0,24"
              HorizontalAlignment="Center"
              VerticalAlignment="Stretch"
              Opacity="{Binding IsWorkflowDialogVisible, Converter={StaticResource BoolToDoubleConverter}, ConverterParameter='1,0'}"
              IsVisible="{Binding IsWorkflowDialogVisible}"
              attached:DialogEntranceMotion.IsEnabled="True"
              ZIndex="1001">
            <Border Width="640"
                    MaxHeight="680"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="{DynamicResource FrpSurfaceWhiteBrush}"
                    BorderBrush="{DynamicResource FrpBorderDefaultBrush}"
                    BorderThickness="1"
                    BoxShadow="{DynamicResource FrpShadowDialog}"
                    CornerRadius="{DynamicResource FrpRadiusPanel}"
                    ClipToBounds="True">
                <ContentControl HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Content="{Binding CurrentModalDialog}" />
            </Border>
        </Grid>
    </Grid>
</Window>
