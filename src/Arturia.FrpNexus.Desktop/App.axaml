<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Arturia.FrpNexus.Desktop"
             xmlns:converters="using:Arturia.FrpNexus.Desktop.Converters"
             x:Class="Arturia.FrpNexus.Desktop.App">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Arturia.FrpNexus.Desktop/Styles/DesignTokens.axaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:StatusTextConverter x:Key="StatusTextConverter" />
            <converters:StatusClassesConverter x:Key="StatusClassesConverter" />
            <converters:TunnelProtocolTextConverter x:Key="TunnelProtocolTextConverter" />
            <converters:NavigationIconConverter x:Key="NavigationIconConverter" />
        </ResourceDictionary>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
        <StyleInclude Source="avares://Arturia.FrpNexus.Desktop/Styles/Controls.axaml" />
        <StyleInclude Source="avares://Arturia.FrpNexus.Desktop/Styles/Navigation.axaml" />
        <StyleInclude Source="avares://Arturia.FrpNexus.Desktop/Styles/Status.axaml" />
        <StyleInclude Source="avares://Arturia.FrpNexus.Desktop/Styles/CodePanels.axaml" />
    </Application.Styles>
</Application>
