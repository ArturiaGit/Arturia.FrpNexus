<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:templatedControls="using:Avalonia.Controls.Templates">
    <Style Selector="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Ui}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineHeight" Value="20" />
    </Style>

    <Style Selector="TextBlock.page-title">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="LineHeight" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.metric-value">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="LineHeight" Value="30" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.section-title">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="LineHeight" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.group-label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineHeight" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.helper">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="18" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
    </Style>

    <Style Selector="TextBlock.code">
        <Setter Property="FontFamily" Value="{StaticResource Font.Code}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="18" />
    </Style>

    <Style Selector="Border.panel">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceWhiteBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource FrpRadiusPanel}" />
        <Setter Property="BoxShadow" Value="0 1 2 0 #1419231F" />
    </Style>

    <Style Selector="Border.metric-tile">
        <Setter Property="Padding" Value="18,16" />
        <Setter Property="MinHeight" Value="82" />
    </Style>

    <Style Selector="Border.subtle-panel">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceLowBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource FrpRadiusControl}" />
    </Style>

    <Style Selector="Border.command-bar">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceWhiteBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource FrpRadiusPanel}" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style Selector="Border.page-toolbar">
        <Setter Property="Padding" Value="12" />
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceWhiteBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Grid.page-toolbar">
        <Setter Property="ColumnSpacing" Value="12" />
    </Style>

    <Style Selector="Grid.search-box">
        <Setter Property="Height" Value="34" />
    </Style>

    <Style Selector="Border.search-box">
        <Setter Property="Width" Value="256" />
        <Setter Property="Height" Value="34" />
    </Style>

    <Style Selector="Border.side-panel">
        <Setter Property="Width" Value="320" />
        <Setter Property="Margin" Value="20,0,0,0" />
    </Style>

    <Style Selector="StackPanel.form-section">
        <Setter Property="Margin" Value="16" />
        <Setter Property="Spacing" Value="12" />
    </Style>

    <Style Selector="PathIcon.command-icon">
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
    </Style>

    <Style Selector="PathIcon.small-command-icon">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
    </Style>

    <Style Selector="Border.incident-row">
        <Setter Property="Padding" Value="12" />
        <Setter Property="Background" Value="#1AFFDAD6" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpStatusErrorBrush}" />
        <Setter Property="BorderThickness" Value="3,0,0,0" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="Border.table-row">
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Padding" Value="0,8" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
    </Style>

    <Style Selector="TextBlock.table-header">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextSecondaryBrush}" />
    </Style>

    <Style Selector="TextBlock.material-symbol">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Border.required-badge">
        <Setter Property="Height" Value="18" />
        <Setter Property="Padding" Value="6,0" />
        <Setter Property="CornerRadius" Value="{DynamicResource FrpRadiusSmall}" />
        <Setter Property="Background" Value="{DynamicResource FrpSelectionSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.required-badge-text">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="Foreground" Value="{DynamicResource FrpPrimaryBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="ToolTip.stitch-tooltip">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceWhiteBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource FrpRadiusSmall}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Ui}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        BoxShadow="0 4 12 0 #14192324">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Padding="{TemplateBinding Padding}"
                                      TextBlock.Foreground="{TemplateBinding Foreground}"
                                      TextBlock.FontFamily="{TemplateBinding FontFamily}"
                                      TextBlock.FontSize="{TemplateBinding FontSize}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.quick-action">
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="Height" Value="38" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="PART_ButtonChrome"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <ContentPresenter x:Name="PART_ContentPresenter"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      TextBlock.Foreground="{TemplateBinding Foreground}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.quick-action PathIcon">
        <Setter Property="Foreground" Value="{Binding $parent[Button].Foreground}" />
    </Style>

    <Style Selector="Button.quick-action TextBlock">
        <Setter Property="Foreground" Value="{Binding $parent[Button].Foreground}" />
    </Style>

    <Style Selector="Button.view-all-link">
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Padding" Value="6,0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource FrpPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{DynamicResource FrpRadiusSmall}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      TextBlock.Foreground="{TemplateBinding Foreground}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.view-all-link:pointerover">
        <Setter Property="Background" Value="{DynamicResource FrpStatusInfoSoftBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpPrimaryHoverBrush}" />
    </Style>

    <Style Selector="Button.view-all-link:pressed">
        <Setter Property="Background" Value="{DynamicResource FrpSelectionSubtleBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpPrimaryHoverBrush}" />
    </Style>

    <Style Selector="Button.view-all-link TextBlock">
        <Setter Property="Foreground" Value="{Binding $parent[Button].Foreground}" />
    </Style>

    <Style Selector="Border.dashboard-status-badge">
        <Setter Property="CornerRadius" Value="{DynamicResource FrpRadiusControl}" />
        <Setter Property="Padding" Value="8,2" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.dashboard-status-badge.success">
        <Setter Property="Background" Value="{DynamicResource FrpStatusSuccessSoftBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpStatusSuccessBorderBrush}" />
    </Style>

    <Style Selector="Border.dashboard-status-badge.warning">
        <Setter Property="Background" Value="{DynamicResource FrpStatusWarningSoftBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpStatusWarningBorderBrush}" />
    </Style>

    <Style Selector="Border.dashboard-status-badge.error">
        <Setter Property="Background" Value="{DynamicResource FrpStatusErrorSoftBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpStatusErrorBorderBrush}" />
    </Style>

    <Style Selector="Border.dashboard-status-badge.neutral">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceVariantBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
    </Style>

    <Style Selector="Border.realtime-badge">
        <Setter Property="Height" Value="24" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="CornerRadius" Value="{DynamicResource FrpRadiusControl}" />
        <Setter Property="Background" Value="#1A16A34A" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="StackPanel.info-section">
        <Setter Property="Spacing" Value="8" />
    </Style>

    <Style Selector="Border.settings-card">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceWhiteBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource FrpRadiusPanel}" />
        <Setter Property="BoxShadow" Value="0 1 2 0 #14192314" />
    </Style>

    <Style Selector="Border.settings-divider">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{DynamicResource FrpBorderDefaultBrush}" />
        <Setter Property="Opacity" Value="0.7" />
    </Style>

    <Style Selector="Button">
        <Setter Property="FontFamily" Value="{StaticResource Font.Ui}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="CornerRadius" Value="{DynamicResource FrpRadiusControl}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button:focus-visible">
        <Setter Property="BorderBrush" Value="{DynamicResource FrpFocusRingBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <Style Selector="Button.primary">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Background" Value="{DynamicResource FrpPrimaryBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpOnPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Button.primary:pointerover">
        <Setter Property="Background" Value="{DynamicResource FrpPrimaryHoverBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpOnPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpPrimaryHoverBrush}" />
    </Style>

    <Style Selector="Button.primary:pressed">
        <Setter Property="Background" Value="{DynamicResource FrpPrimaryBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpOnPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpPrimaryBrush}" />
    </Style>

    <Style Selector="Button.primary:focus-visible">
        <Setter Property="BorderBrush" Value="{DynamicResource FrpFocusRingBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Button.secondary:pointerover">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceContainerBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
    </Style>

    <Style Selector="Button.icon-secondary">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource FrpRadiusSmall}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      TextBlock.Foreground="{TemplateBinding Foreground}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.icon-secondary:pointerover">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceContainerBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
    </Style>

    <Style Selector="Button.icon-secondary:pressed">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceHighBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
    </Style>

    <Style Selector="Button.icon-secondary:focus-visible">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceWhiteBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpFocusRingBrush}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Foreground" Value="{DynamicResource FrpPrimaryBrush}" />
    </Style>

    <Style Selector="Button.icon-secondary PathIcon">
        <Setter Property="Foreground" Value="{Binding $parent[Button].Foreground}" />
    </Style>

    <Style Selector="Button.stitch-command">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      TextBlock.Foreground="{TemplateBinding Foreground}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.stitch-command PathIcon">
        <Setter Property="Foreground" Value="{Binding $parent[Button].Foreground}" />
    </Style>

    <Style Selector="Button.stitch-command TextBlock">
        <Setter Property="Foreground" Value="{Binding $parent[Button].Foreground}" />
    </Style>

    <Style Selector="Button.stitch-command.secondary:pressed">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceHighBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
    </Style>

    <Style Selector="Button.stitch-command.danger">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceWhiteBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpStatusErrorBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpStatusErrorBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Button.stitch-command.danger:pointerover">
        <Setter Property="Background" Value="{DynamicResource FrpStatusErrorSoftBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpStatusErrorBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpStatusErrorBrush}" />
    </Style>

    <Style Selector="Button.stitch-command.danger:pressed">
        <Setter Property="Background" Value="{DynamicResource FrpDangerPressedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpStatusErrorBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpStatusErrorBrush}" />
    </Style>

    <Style Selector="Button.stitch-command:disabled">
        <Setter Property="Opacity" Value="0.55" />
        <Setter Property="Cursor" Value="Arrow" />
    </Style>

    <Style Selector="Button.stitch-command:focus-visible">
        <Setter Property="BorderBrush" Value="{DynamicResource FrpFocusRingBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <Style Selector="Button.stitch-command:disabled:focus-visible">
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="CheckBox.stitch-checkbox">
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Ui}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid ColumnDefinitions="18,*"
                      ColumnSpacing="8"
                      MinHeight="{TemplateBinding MinHeight}"
                      Cursor="{TemplateBinding Cursor}">
                    <Border x:Name="CheckBoxGlyph"
                            Width="18"
                            Height="18"
                            Background="{DynamicResource FrpSurfaceWhiteBrush}"
                            BorderBrush="{DynamicResource FrpBorderDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource FrpRadiusSmall}"
                            VerticalAlignment="Center">
                        <PathIcon Width="12"
                                  Height="12"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource FrpOnPrimaryBrush}"
                                  Data="M 10.6,3.4 L 5,9 L 2.4,6.4 L 1.4,7.4 L 5,11 L 11.6,4.4 Z"
                                  IsVisible="{TemplateBinding IsChecked}" />
                    </Border>
                    <ContentPresenter Grid.Column="1"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      VerticalAlignment="Center"
                                      TextBlock.Foreground="{TemplateBinding Foreground}" />
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="CheckBox.stitch-checkbox:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource FrpTextPrimaryBrush}" />
    </Style>

    <Style Selector="CheckBox.stitch-checkbox:pointerover /template/ Border#CheckBoxGlyph">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceLowBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpOutlineVariantBrush}" />
    </Style>

    <Style Selector="CheckBox.stitch-checkbox:checked /template/ Border#CheckBoxGlyph">
        <Setter Property="Background" Value="{DynamicResource FrpPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpPrimaryBrush}" />
    </Style>

    <Style Selector="CheckBox.stitch-checkbox:disabled">
        <Setter Property="Foreground" Value="{DynamicResource FrpTextMutedBrush}" />
        <Setter Property="Cursor" Value="Arrow" />
    </Style>

    <Style Selector="CheckBox.stitch-checkbox:disabled /template/ Border#CheckBoxGlyph">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceLowBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
    </Style>

    <Style Selector="Button.node-row">
        <Setter Property="Height" Value="40" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.node-row:pointerover">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceLowBrush}" />
    </Style>

    <Style Selector="Button.node-row:pressed">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceContainerBrush}" />
    </Style>

    <Style Selector="Button.compact">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Padding" Value="10,0" />
    </Style>

    <Style Selector="CheckBox.stitch-check">
        <Setter Property="FontFamily" Value="{StaticResource Font.Ui}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextPrimaryBrush}" />
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceWhiteBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate>
                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <Border Width="18"
                            Height="18"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource FrpRadiusSmall}">
                        <PathIcon x:Name="PART_CheckMark"
                                  Width="13"
                                  Height="13"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsVisible="False"
                                  Foreground="{DynamicResource FrpOnPrimaryBrush}"
                                  Data="M 4.5,9.2 L 2.1,6.8 L 1.1,7.8 L 4.5,11.2 L 12.9,2.8 L 11.9,1.8 Z" />
                    </Border>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      VerticalContentAlignment="Center"
                                      TextBlock.Foreground="{TemplateBinding Foreground}" />
                </StackPanel>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="CheckBox.stitch-check:pointerover">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceLowBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpOutlineVariantBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextPrimaryBrush}" />
    </Style>

    <Style Selector="CheckBox.stitch-check:pressed">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceHighBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpOutlineVariantBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextPrimaryBrush}" />
    </Style>

    <Style Selector="CheckBox.stitch-check:checked">
        <Setter Property="Background" Value="{DynamicResource FrpPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpPrimaryBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextPrimaryBrush}" />
    </Style>

    <Style Selector="CheckBox.stitch-check:checked:pointerover">
        <Setter Property="Background" Value="{DynamicResource FrpPrimaryHoverBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpPrimaryHoverBrush}" />
    </Style>

    <Style Selector="CheckBox.stitch-check:checked:pressed">
        <Setter Property="Background" Value="{DynamicResource FrpPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpPrimaryBrush}" />
    </Style>

    <Style Selector="CheckBox.stitch-check:checked /template/ PathIcon#PART_CheckMark">
        <Setter Property="IsVisible" Value="True" />
    </Style>

    <Style Selector="CheckBox.stitch-check:disabled">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceLowBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextSecondaryBrush}" />
        <Setter Property="Opacity" Value="0.55" />
        <Setter Property="Cursor" Value="Arrow" />
    </Style>

    <Style Selector="TextBox, ComboBox">
        <Setter Property="FontFamily" Value="{StaticResource Font.Ui}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource FrpRadiusSmall}" />
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceWhiteBrush}" />
    </Style>

    <Style Selector="TextBox.stitch-input">
        <Setter Property="Height" Value="34" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceWhiteBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource FrpRadiusSmall}" />
        <Setter Property="CaretBrush" Value="{DynamicResource FrpPrimaryBrush}" />
        <Setter Property="Cursor" Value="IBeam" />
        <Setter Property="SelectionBrush" Value="{DynamicResource FrpInputSelectionBrush}" />
        <Setter Property="SelectionForegroundBrush" Value="{DynamicResource FrpTextPrimaryBrush}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="PART_InputChrome"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Cursor="IBeam">
                    <Grid>
                        <TextPresenter Name="PART_TextPresenter"
                                       Margin="{TemplateBinding Padding}"
                                       VerticalAlignment="Center"
                                       Cursor="IBeam"
                                       IsHitTestVisible="True"
                                       Text="{TemplateBinding Text}"
                                       PasswordChar="{TemplateBinding PasswordChar}"
                                       RevealPassword="{TemplateBinding RevealPassword}"
                                       CaretBrush="{TemplateBinding CaretBrush}"
                                       CaretIndex="{TemplateBinding CaretIndex}"
                                       SelectionStart="{TemplateBinding SelectionStart}"
                                       SelectionEnd="{TemplateBinding SelectionEnd}"
                                       SelectionBrush="{TemplateBinding SelectionBrush}"
                                       SelectionForegroundBrush="{TemplateBinding SelectionForegroundBrush}"
                                       ShowSelectionHighlight="True" />
                        <TextBlock Name="PART_PlaceholderText"
                                   Margin="{TemplateBinding Padding}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource FrpTextSecondaryBrush}"
                                   Opacity="0.75"
                                   Text="{TemplateBinding PlaceholderText}"
                                   Cursor="IBeam"
                                   IsHitTestVisible="False" />
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="TextBox.stitch-input:pointerover">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceWhiteBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpOutlineVariantBrush}" />
    </Style>

    <Style Selector="TextBox.stitch-input:focus">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceWhiteBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpPrimaryBrush}" />
    </Style>

    <Style Selector="TextBox.stitch-input:disabled">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceLowBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
    </Style>

    <Style Selector="TextBox.stitch-input:not(:empty) /template/ TextBlock#PART_PlaceholderText">
        <Setter Property="IsVisible" Value="False" />
    </Style>

    <Style Selector="TextBox.stitch-input.code">
        <Setter Property="FontFamily" Value="{StaticResource Font.Code}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="ComboBox.stitch-input">
        <Setter Property="Height" Value="34" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceWhiteBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource FrpRadiusSmall}" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="PlaceholderForeground" Value="{DynamicResource FrpTextSecondaryBrush}" />
        <Setter Property="MaxDropDownHeight" Value="240" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid>
                    <Border x:Name="PART_ComboChrome"
                            Height="{TemplateBinding Height}"
                            MinHeight="{TemplateBinding MinHeight}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Cursor="Hand">
                        <Grid ColumnDefinitions="*,32">
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              TextBlock.Foreground="{TemplateBinding Foreground}" />
                            <PathIcon Grid.Column="1"
                                      Width="14"
                                      Height="14"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Cursor="Hand"
                                      Foreground="{TemplateBinding Foreground}"
                                      Data="M 2,4 L 7,9 L 12,4 Z" />
                        </Grid>
                    </Border>

                    <Popup Name="PART_Popup"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           IsLightDismissEnabled="True"
                           OverlayDismissEventPassThrough="True"
                           Placement="BottomEdgeAlignedLeft"
                           MinWidth="{Binding Bounds.Width, RelativeSource={RelativeSource TemplatedParent}}">
                        <Border Margin="0,4,0,0"
                                Background="{DynamicResource FrpSurfaceWhiteBrush}"
                                BorderBrush="{DynamicResource FrpBorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource FrpRadiusPanel}"
                                BoxShadow="0 4 12 0 #14192324">
                            <ScrollViewer MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsPresenter Name="PART_ItemsPresenter"
                                                Margin="0,4" />
                            </ScrollViewer>
                        </Border>
                    </Popup>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="ComboBox.stitch-input:pointerover">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceWhiteBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpOutlineVariantBrush}" />
    </Style>

    <Style Selector="ComboBox.stitch-input:focus">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceWhiteBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpPrimaryBrush}" />
    </Style>

    <Style Selector="ComboBox.stitch-input:pressed">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceWhiteBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpPrimaryBrush}" />
    </Style>

    <Style Selector="ComboBox.stitch-input:disabled">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceLowBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
    </Style>

    <Style Selector="ComboBox.stitch-input ComboBoxItem">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceWhiteBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextPrimaryBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="PART_ItemChrome"
                        MinHeight="{TemplateBinding MinHeight}"
                        Margin="4,0"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{DynamicResource FrpRadiusSmall}"
                        Cursor="Hand">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      TextBlock.Foreground="{TemplateBinding Foreground}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="ComboBox.stitch-input ComboBoxItem:pointerover">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceLowBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextPrimaryBrush}" />
    </Style>

    <Style Selector="ComboBox.stitch-input ComboBoxItem:pressed">
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceContainerBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpTextPrimaryBrush}" />
    </Style>

    <Style Selector="ComboBox.stitch-input ComboBoxItem:selected">
        <Setter Property="Background" Value="{DynamicResource FrpSelectionSubtleBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpPrimaryBrush}" />
    </Style>

    <Style Selector="ComboBox.stitch-input ComboBoxItem:selected:pointerover">
        <Setter Property="Background" Value="{DynamicResource FrpSelectionSubtleBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FrpPrimaryBrush}" />
    </Style>

    <Style Selector="TextBox.code">
        <Setter Property="FontFamily" Value="{StaticResource Font.Code}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="DataGrid">
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="BorderBrush" Value="{DynamicResource FrpBorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="RowHeight" Value="40" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Ui}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Background" Value="{DynamicResource FrpSurfaceWhiteBrush}" />
    </Style>
</Styles>
