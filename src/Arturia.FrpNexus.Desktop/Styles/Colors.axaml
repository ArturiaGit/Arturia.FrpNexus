<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Styles.Resources>
        <Color x:Key="FrpNexusColorWindowBackground">#F3F3F3</Color>
        <Color x:Key="FrpNexusColorSurfaceCard">#FFFFFF</Color>
        <Color x:Key="FrpNexusColorBorderLowContrast">#E5E5E5</Color>
        <Color x:Key="FrpNexusColorAccent">#D4A017</Color>
        <Color x:Key="FrpNexusColorAccentPressed">#B8890F</Color>
        <Color x:Key="FrpNexusColorAccentSubtle">#FFF4D6</Color>
        <Color x:Key="FrpNexusColorTextPrimary">#E4000000</Color>
        <Color x:Key="FrpNexusColorTextSecondary">#9E000000</Color>
        <Color x:Key="FrpNexusColorTextOnAccent">#FFFFFF</Color>
        <Color x:Key="FrpNexusColorTerminalBackground">#1C1C1C</Color>
        <Color x:Key="FrpNexusColorTerminalBorder">#2A2A2A</Color>
        <Color x:Key="FrpNexusColorTerminalText">#F2F2F2</Color>
        <Color x:Key="FrpNexusColorControlHover">#F7F7F7</Color>
        <Color x:Key="FrpNexusColorControlPressed">#EFEFEF</Color>
        <Color x:Key="FrpNexusColorError">#BA1A1A</Color>

        <SolidColorBrush x:Key="FrpNexusWindowBackgroundBrush" Color="{StaticResource FrpNexusColorWindowBackground}" />
        <SolidColorBrush x:Key="FrpNexusSurfaceCardBrush" Color="{StaticResource FrpNexusColorSurfaceCard}" />
        <SolidColorBrush x:Key="FrpNexusBorderLowContrastBrush" Color="{StaticResource FrpNexusColorBorderLowContrast}" />
        <SolidColorBrush x:Key="FrpNexusAccentBrush" Color="{StaticResource FrpNexusColorAccent}" />
        <SolidColorBrush x:Key="FrpNexusAccentPressedBrush" Color="{StaticResource FrpNexusColorAccentPressed}" />
        <SolidColorBrush x:Key="FrpNexusAccentSubtleBrush" Color="{StaticResource FrpNexusColorAccentSubtle}" />
        <SolidColorBrush x:Key="FrpNexusTextPrimaryBrush" Color="{StaticResource FrpNexusColorTextPrimary}" />
        <SolidColorBrush x:Key="FrpNexusTextSecondaryBrush" Color="{StaticResource FrpNexusColorTextSecondary}" />
        <SolidColorBrush x:Key="FrpNexusTextOnAccentBrush" Color="{StaticResource FrpNexusColorTextOnAccent}" />
        <SolidColorBrush x:Key="FrpNexusTerminalBackgroundBrush" Color="{StaticResource FrpNexusColorTerminalBackground}" />
        <SolidColorBrush x:Key="FrpNexusTerminalBorderBrush" Color="{StaticResource FrpNexusColorTerminalBorder}" />
        <SolidColorBrush x:Key="FrpNexusTerminalTextBrush" Color="{StaticResource FrpNexusColorTerminalText}" />
        <SolidColorBrush x:Key="FrpNexusControlHoverBrush" Color="{StaticResource FrpNexusColorControlHover}" />
        <SolidColorBrush x:Key="FrpNexusControlPressedBrush" Color="{StaticResource FrpNexusColorControlPressed}" />
        <SolidColorBrush x:Key="FrpNexusErrorBrush" Color="{StaticResource FrpNexusColorError}" />
    </Styles.Resources>
</Styles>
