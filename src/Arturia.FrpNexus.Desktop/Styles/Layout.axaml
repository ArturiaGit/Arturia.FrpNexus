<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Styles.Resources>
        <CornerRadius x:Key="FrpNexusCornerRadiusControl">4</CornerRadius>
        <CornerRadius x:Key="FrpNexusCornerRadiusCard">8</CornerRadius>
        <CornerRadius x:Key="FrpNexusCornerRadiusLarge">12</CornerRadius>

        <Thickness x:Key="FrpNexusSpaceNone">0</Thickness>
        <Thickness x:Key="FrpNexusSpaceStandard">8</Thickness>
        <Thickness x:Key="FrpNexusSpaceTerminalInner">12</Thickness>
        <Thickness x:Key="FrpNexusSpaceFormGutter">16</Thickness>
        <Thickness x:Key="FrpNexusSpaceSectionPadding">24</Thickness>
        <Thickness x:Key="FrpNexusCardMarginTop">0,24,0,0</Thickness>

        <x:Double x:Key="FrpNexusSpacingSmall">8</x:Double>
        <x:Double x:Key="FrpNexusSpacingMedium">12</x:Double>
        <x:Double x:Key="FrpNexusSpacingFormGutter">16</x:Double>
        <x:Double x:Key="FrpNexusSpacingSection">24</x:Double>
    </Styles.Resources>

    <Style Selector="Border.frpnexus-card">
        <Setter Property="Background" Value="{StaticResource FrpNexusSurfaceCardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource FrpNexusBorderLowContrastBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource FrpNexusCornerRadiusCard}" />
        <Setter Property="Padding" Value="{StaticResource FrpNexusSpaceSectionPadding}" />
    </Style>

    <Style Selector="Border.frpnexus-terminal">
        <Setter Property="Background" Value="{StaticResource FrpNexusTerminalBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource FrpNexusTerminalBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource FrpNexusCornerRadiusCard}" />
        <Setter Property="Padding" Value="{StaticResource FrpNexusSpaceTerminalInner}" />
    </Style>
</Styles>
